# ACTION=promote
# PROMOTE_NAMESPACE=prod
# CONFIRM_PROMOTION=true


# Default values. Must be rolled back to these after git push.
ACTION=none
PROMOTE_NAMESPACE=prod
CONFIRM_PROMOTION=false


# Jenkins now promotes changed app services automatically using the current short Git SHA.
# Example: if services/order-service/* and services/payment-service/* changed in the
# same confirmed promotion commit, Jenkins builds/deploys those services to dev/test
# and then promotes order-service:<current-sha> and payment-service:<current-sha> to prod.
#
# Note: control-plane-service is still not in promotion flow (by design right now).
