# ACTION=promote
# PROMOTE_NAMESPACE=prod
# PROMOTE_SERVICES=
# CONFIRM_PROMOTION=true

# Default values. Must be rolled back to these after git push.
ACTION=none
PROMOTE_NAMESPACE=prod
PROMOTE_SERVICES=
CONFIRM_PROMOTION=false


# Jenkins promotes existing dev images to prod.
# Leave PROMOTE_SERVICES blank to promote every supported app service where dev differs from prod.
# Or set a comma-separated service-name allowlist, no tags:
# PROMOTE_SERVICES=order-service,payment-service
#
# Note: control-plane-service is still not in promotion flow (by design right now).
